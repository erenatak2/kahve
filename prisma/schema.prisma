generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("MUSTERI")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer  Customer?
  sellerCustomers Customer[] @relation("SalesRepToCustomer")
  accounts  Account[]
  sessions  Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id              String   @id @default(cuid())
  userId          String   @unique
  phone           String?
  address         String?  // Fatura adresi (billingAddress)
  shippingAddress String?  // Teslimat adresi
  city            String?
  taxNumber       String?
  taxOffice       String?
  businessName    String?
  discountRate    Float    @default(0)
  salesRepId      String?  // Satış Temsilcisi (Plasiyer) bağlantısı
  notes           String?
  isActive        Boolean  @default(true)
  
  // Takip (CRM) Alanları
  nextCallDate    DateTime?
  followUpStatus  String    @default("BEKLIYOR") // BEKLIYOR, ARANDI
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesRep             User?                 @relation("SalesRepToCustomer", fields: [salesRepId], references: [id])
  orders               Order[]
  customerPrices       CustomerPrice[]
  paymentNotifications PaymentNotification[]
}

model Product {
  id           String   @id @default(cuid())
  code         String?
  name         String
  category     String   @default("Genel")
  description  String?
  purchasePrice String?
  salePrice    Float
  stock        Int      @default(0)
  minStock     Int      @default(5)
  unit         String   @default("Adet")
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems     OrderItem[]
  customerPrices CustomerPrice[]
}

model CustomerPrice {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String?  // Sipariş no: SP-YYYYMMDD-XXXX
  customerId      String
  status          String   @default("HAZIRLANIYOR")
  totalAmount     Float    @default(0)
  notes           String?
  orderDate       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  billingAddress  String?  // Fatura adresi
  shippingAddress String?  // Teslimat adresi
  paymentMethod   String?  // Ödeme yöntemi: NAKIT, HAVALE, KREDI_KARTI, CEK, ACIK_HESAP
  cargoCompany    String?  // Kargo firması
  trackingNumber  String?  // Kargo takip numarası

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  payments   Payment[]
  paymentNotifications PaymentNotification[]

  // Hatırlatıcılar ve Takip
  deliveredAt    DateTime? // Teslimat tarihi
  followupStatus String    @default("BEKLIYOR") // BEKLIYOR, ARANDI
  reminderAt     DateTime? // Hatırlatma (Arama) tarihi
  reminderNote   String?   // Hatırlatma notu
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  total     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id              String   @id @default(cuid())
  orderId         String
  amount          Float
  method          String   @default("NAKIT") // NAKIT, KREDI_KARTI, HAVALE, CEK
  status          String   @default("BEKLIYOR") // BEKLIYOR, ODENDI, GECIKTI, IPTAL
  
  // Kredi kartı bilgileri (tokenized)
  cardToken       String?  // İyzico/Stripe token
  conversationId  String?  // Ödeme sağlayıcı işlem ID
  
  // Ödeme zamanları
  paidAt          DateTime?
  dueDate         DateTime?
  
  // Ödeme aşaması (teslim öncesi/sonrası)
  paymentTiming   String   @default("TESLIM_SONRASI") // TESLIM_ONCESI, TESLIM_SONRASI
  
  notes           String?
  createdAt       DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Ödeme bildirimleri (müşteri havale yapınca bildirim)
model PaymentNotification {
  id              String   @id @default(cuid())
  orderId         String
  customerId      String
  amount          Float
  bankName        String?  // Hangi bankaya gönderdi
  senderName      String?  // Gönderen adı
  receiptUrl      String?  // Dekont/resim URL
  notes           String?  // Müşteri notu
  status          String   @default("BEKLIYOR") // BEKLIYOR, ONAYLANDI, REDDEDILDI
  adminNotes      String?  // Admin reddederken/onaylarken not
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}
